--- !u!114 &1441201923
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1441201921}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1a07c424d7d801c45be90437e6cf800f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogsRoot
  _currentLevelPhrases:
  - Phrase: "\u0411\u043E\u0435\u0446, \u0442\u0435\u0431\u0435 \u043E\u043A\u0430\u0437\u0430\u043D\u0430
      \u0432\u0435\u043B\u0438\u043A\u0430\u044F \u0447\u0435\u0441\u0442\u044C!
      \u041D\u0430\u0448\u0430 \u043A\u0430\u043C\u043F\u0430\u043D\u0438\u044F \u0434\u043E\u0441\u0442\u0438\u0433\u043B\u0430
      \u0442\u0435\u0440\u043C\u0438\u043D\u0430\u043B\u044C\u043D\u043E\u0439 \u0441\u0442\u0430\u0434\u0438\u0438!\L\u0422\u044B
      \u0434\u043E\u043B\u0436\u0435\u043D \u043F\u0440\u043E\u0440\u0432\u0430\u0442\u044C\u0441\u044F
      \u043A \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0435, \u0438 \u043F\u043E\u043B\u043E\u0436\u0438\u0442\u044C
      \u043A\u043E\u043D\u0435\u0446 \u0432\u043E\u0439\u043D\u0435."
    Color: {r: 1, g: 1, b: 1, a: 1}
  - Phrase: "\u0425\u043E\u0440\u043E\u0448\u0438\u0435 \u043F\u0430\u0440\u043D\u0438
      \u0437\u0430\u0432\u0435\u0440\u0448\u0430\u044E\u0442 \u0432\u043E\u0439\u043D\u044B,
      \u0430 \u043C\u044B - \u0445\u043E\u0440\u043E\u0448\u0438\u0435 \u043F\u0430\u0440\u043D\u0438,
      \u0441\u043E\u043B\u0434\u0430\u0442!\L\u041F\u043E\u0431\u0435\u0434\u0430
      \u0431\u0443\u0434\u0435\u0442 \u0437\u0430 \u043D\u0430\u043C\u0438!"
    Color: {r: 1, g: 1, b: 1, a: 1}
  - Phrase: "\u0422\u044B \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0438, \u0443
      \u043D\u0438\u0445 \u0432\u0441\u0451 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
      \u043F\u043B\u043E\u0445\u043E, \u0447\u0442\u043E \u043E\u043D\u0438 \u043F\u0440\u0438\u0437\u044B\u0432\u0430\u044E\u0442
      \u0432 \u0430\u0440\u043C\u0438\u044E \u0431\u0440\u043E\u0434\u044F\u0433
      \u0438 \u043C\u0443\u0441\u043E\u0440\u0449\u0438\u043A\u043E\u0432..\L\u042D\u0442\u043E
      \u041C\u0430\u043A\u0440\u043E\u0444\u0430\u0433\u0438, \u0431\u043E\u0435\u0446,
      \u0436\u0430\u043B\u043A\u0438\u0439 \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u0438\u043A.
      \u0418\u0441\u0442\u0440\u0435\u0431\u043B\u044F\u0439 \u0438\u0445 \u0431\u0435\u0437
      \u0436\u0430\u043B\u043E\u0441\u0442\u0438!"
    Color: {r: 1, g: 1, b: 1, a: 1}
  - Phrase: "\u041E\u043D \u0443\u043A\u0440\u0430\u043B \u043D\u0430\u0448 \u043A\u0440\u0438\u0441\u0442\u0430\u043B!
      \u041D\u0430\u043A\u0430\u0436\u0438 \u0435\u0433\u043E \u043A\u0430\u043A
      \u0441\u043B\u0435\u0434\u0443\u0435\u0442! \u0417\u0430 \u044D\u0442\u0438
      \u043A\u0440\u0438\u0441\u0442\u0430\u043B\u043B\u044B \u043C\u044B \u0432\u044B\u0434\u0430\u0434\u0438\u043C
      \u0442\u0435\u0431\u0435 \u043D\u043E\u0432\u044B\u0435 \u043F\u0443\u0448\u043A\u0438,
      \u0431\u043E\u0435\u0446. \u0422\u0430\u043A \u0447\u0442\u043E \u0441\u043E\u0431\u0438\u0440\u0430\u0439
      \u0438\u0445 \u0432\u0441\u0435!"
    Color: {r: 1, g: 1, b: 1, a: 1}
  - Phrase: "\u041F\u0435\u0440\u0435\u0434 \u0442\u043E\u0431\u043E\u0439 \u0441\u0435\u0440\u044C\u0451\u0437\u043D\u044B\u0439
      \u0432\u0440\u0430\u0433, \u0422-\u043A\u0438\u043B\u043B\u0435\u0440\u044B.
      \u0421\u043E\u043B\u0434\u0430\u0442\u044B \u0442\u0435\u0440\u0440\u043E\u0440\u0438\u0441\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0433\u043E
      \u0440\u0435\u0436\u0438\u043C\u0430. \u042D\u0442\u043E \u043E\u043F\u0430\u0441\u043D\u044B\u0435
      \u0440\u0435\u0431\u044F\u0442\u0430, \u0431\u043E\u0435\u0446. \u0423\u0441\u0442\u0440\u0430\u043D\u044F\u0439
      \u0438\u0445 \u043F\u0435\u0440\u0432\u044B\u043C\u0438!"
    Color: {r: 1, g: 1, b: 1, a: 1}
  - Phrase: "\u0425\u043C\u043C, \u043F\u043E\u0441\u043B\u0435 \u0441\u043C\u0435\u0440\u0442\u0438
      \u043E\u043D\u0438 \u0432\u0437\u0440\u044B\u0432\u0430\u044E\u0442\u0441\u044F...
      \u0437\u0430\u0431\u044B\u043B \u0442\u0435\u0431\u0435 \u0441\u043A\u0430\u0437\u0430\u0442\u044C.
      \u0423\u0432\u043E\u0440\u0430\u0447\u0438\u0432\u0430\u0439\u0441\u044F, \u043D\u0435
      \u0441\u0442\u043E\u0439 \u0441\u0442\u043E\u043B\u0431\u043E\u043C! \u041A\u0442\u043E
      \u043F\u043E\u0433\u0438\u0431\u043D\u0435\u0442 - \u0442\u043E\u0442 \u043C\u0438\u0441\u0441\u0438\u044E
      \u043D\u0435 \u0432\u044B\u043F\u043E\u043B\u043D\u0438\u0442!"
    Color: {r: 1, g: 1, b: 1, a: 1}
  - Phrase: "\u0422\u044B \u0434\u043E\u0441\u0442\u0430\u0432\u0438\u043B \u0438\u043C
      \u043D\u0435\u043C\u0430\u043B\u043E \u0445\u043B\u043E\u043F\u043E\u0442,
      \u0438 \u043E\u043D\u0438 \u0432\u044B\u0437\u0432\u0430\u043B\u0438 \u0411-\u043B\u0438\u043C\u0444\u043E\u0446\u0438\u0442\u044B.
      \u042D\u0442\u043E \u043E\u0444\u0438\u0446\u0435\u0440\u0430, \u0438 \u043E\u043D\u0438
      \u0431\u0443\u0434\u0443\u0442 \u0441\u0442\u0440\u0435\u043B\u044F\u0442\u044C
      \u0432 \u0442\u0435\u0431\u044F. \u0421\u0442\u0440\u0435\u043B\u044F\u0439
      \u043F\u0435\u0440\u0432\u044B\u043C!"
    Color: {r: 1, g: 1, b: 1, a: 1}
  - Phrase: "\u041C\u044B \u0432 \u0448\u0430\u0433\u0435 \u043E\u0442 \u043F\u043E\u0431\u0435\u0434\u044B,
      \u0431\u043E\u0435\u0446! \u041F\u0435\u0440\u0435\u0434 \u0442\u043E\u0431\u043E\u0439
      - \u0413\u0435\u043D. \u041F\u043E\u0434\u0430\u0432\u0438\u0442\u0435\u043B\u044C.
      \u0420\u0430\u0437\u0431\u0435\u0440\u0438\u0441\u044C \u0441 \u043D\u0438\u043C,
      \u0438 \u043F\u0443\u0442\u044C \u043A \u043A\u043E\u0440\u043E\u043B\u0435\u0432\u0435
      \u0441\u0432\u043E\u0431\u043E\u0434\u0435\u043D."
    Color: {r: 1, g: 1, b: 1, a: 1}
  - Phrase: "\u0411\u043E\u0435\u0446, \u0442\u044B \u0447\u0435\u0433\u043E, \u0443\u043C\u0435\u0440\u0435\u0442\u044C
      \u0443\u0434\u0443\u043C\u0430\u043B? \u0423 \u0420\u043E\u0434\u0438\u043D\u044B
      \u043D\u0430 \u0442\u0435\u0431\u044F \u0431\u043E\u043B\u044C\u0448\u0438\u0435
      \u043F\u043B\u0430\u043D\u044B, \u044F \u043F\u0440\u0438\u043A\u0430\u0437\u044B\u0432\u0430\u044E
      \u0442\u0435\u0431\u0435 \u043D\u0435 \u0443\u043C\u0438\u0440\u0430\u0442\u044C!"
    Color: {r: 1, g: 1, b: 1, a: 1}
  - Phrase: "\u0411\u043E\u0435\u0446, \u0442\u044B \u0432\u044B\u0440\u043E\u0441
      \u043A\u0430\u043A \u043B\u0438\u0447\u043D\u043E\u0441\u0442\u044C! \u041D\u0443,
      \u0435\u0449\u0451 \u0438 \u0441\u043E\u0431\u0440\u0430\u043B \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
      \u043A\u0440\u0438\u0441\u0442\u0430\u043B\u043B\u043E\u0432. \u0412\u044B\u0431\u0438\u0440\u0430\u0439
      \u0441\u0435\u0431\u0435 \u043D\u043E\u0432\u0443\u044E \u043F\u0443\u0448\u043A\u0443!"
    Color: {r: 1, g: 1, b: 1, a: 1}
  - Phrase: "\u0411\u043E\u0435\u0446, \u0442\u044B \u0447\u0442\u043E, \u0440\u0435\u0448\u0438\u043B,
      \u0447\u0442\u043E \u0443 \u0442\u0435\u0431\u044F 9 \u0436\u0438\u0437\u043D\u0435\u0439?
      \u042F \u0442\u0435\u0431\u044F \u043E\u0433\u043E\u0440\u0447\u0443, \u0443
      \u0442\u0435\u0431\u044F \u0432\u0441\u0435\u0433\u043E 3, \u0431\u0435\u0440\u0435\u0433\u0438
      \u0438\u0445 \u0441\u043C\u043E\u043B\u043E\u0434\u0443!"
    Color: {r: 1, g: 1, b: 1, a: 1}
  - Phrase: "\u0414\u0430 \u0442\u044B \u043F\u0440\u043E\u0441\u0442\u043E \u043C\u0430\u0448\u0438\u043D\u0430
      \u0434\u043B\u044F \u0443\u0431\u0438\u0439\u0441\u0442\u0432, \u0431\u043E\u0435\u0446!
      \u041F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u0439 \u0432 \u0442\u043E\u043C
      \u0436\u0435 \u0434\u0443\u0445\u0435 \u0438 \u043F\u043E\u043B\u0443\u0447\u0438\u0448\u044C
      \u043C\u0435\u0434\u0430\u043B\u044C!"
    Color: {r: 1, g: 1, b: 1, a: 1}
